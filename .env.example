# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database (MySQL)
DATABASE_URL="mysql://user:password@localhost:3306/bookhou_prod"

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# Square
SQUARE_ACCESS_TOKEN=xxxx
SQUARE_LOCATION_ID=xxxx
SQUARE_APP_ID=xxxx
SQUARE_ENVIRONMENT=sandbox

# AWS S3
AWS_ACCESS_KEY_ID=xxxx
AWS_SECRET_ACCESS_KEY=xxxx
AWS_S3_BUCKET=bookhou-uploads
AWS_REGION=us-east-1

# Email (SMTP)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=noreply@bookhou.com
MAIL_PASSWORD=xxxx
MAIL_FROM="Bookhou <noreply@bookhou.com>"

# Twilio (SMS Invitations)
TWILIO_ACCOUNT_SID=xxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_PHONE_NUMBER=+1xxxx

# Google Calendar (Service Account)
GOOGLE_CLIENT_EMAIL=bookhou@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nxxxx\n-----END PRIVATE KEY-----"
GOOGLE_CALENDAR_ID=primary

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3001
